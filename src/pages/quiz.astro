---
import BaseLayout from '../layouts/BaseLayout.astro';
import quiz from '../data/quiz.json';

const results = (quiz.results ?? []).slice().sort((a, b) => a.threshold - b.threshold);
const faqs = [
  {
    question: 'Is the "Are You The One or a Program?" quiz canon?',
    answer:
      'No — it is a playful, Matrix-themed personality quiz inspired by the films, not an official test. It is meant for fun and sharing.',
  },
];
---

<BaseLayout
  title="Quiz: Are You The One or Just Another Program?"
  description="A playful Matrix personality quiz. Answer a few questions and find out whether you're The One, a free human, or a machine who doesn't know it yet."
  keywords={['matrix quiz', 'are you the one quiz', 'matrix personality quiz', 'neo quiz']}
  faqs={faqs}
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'Quiz', path: '/quiz' },
  ]}
>
  <div class="container" style="max-width:680px">
    <p class="eyebrow">Interactive</p>
    <h1>Are You The One — or Just Another Program?</h1>
    <p class="lede">{quiz.intro}</p>

    {quiz.questions.length === 0 && <p>The quiz is being assembled.</p>}

    <form id="quizForm">
      {quiz.questions.map((q, qi) => (
        <fieldset class="q">
          <legend>{qi + 1}. {q.q}</legend>
          {q.options.map((o, oi) => (
            <label class="opt">
              <input type="radio" name={`q${qi}`} value={o.machine} data-q={qi} />
              <span>{o.label}</span>
            </label>
          ))}
        </fieldset>
      ))}
    </form>

    {quiz.questions.length > 0 && (
      <button id="reveal" class="cta">Reveal my nature</button>
    )}

    <div id="result" class="result" hidden>
      <p class="eyebrow" id="resultTier"></p>
      <h2 id="resultTitle"></h2>
      <p id="resultBlurb"></p>
      <p>
        <a class="cta ghost" href="/evidence">Now weigh the real evidence →</a>
      </p>
    </div>
  </div>

  <style>
    .q { border: 1px solid var(--border); border-radius: 12px; padding: 16px 18px; margin: 0 0 16px; }
    .q legend { font-weight: 700; padding: 0 8px; color: var(--text); }
    .opt { display: flex; align-items: center; gap: 10px; padding: 8px 0; cursor: pointer; color: var(--text-dim); }
    .opt input { width: 18px; height: 18px; accent-color: var(--accent); }
    .opt:hover { color: var(--text); }
    .result { margin: 28px 0; padding: 24px; border: 1px solid var(--accent); border-radius: 12px; background: var(--accent-soft); }
    #reveal { margin: 8px 0 4px; cursor: pointer; border: none; }
  </style>

  <script define:vars={{ results }}>
    const btn = document.getElementById('reveal');
    if (btn) {
      btn.addEventListener('click', () => {
        const form = document.getElementById('quizForm');
        const radios = form.querySelectorAll('input[type=radio]:checked');
        const total = Array.from(radios).reduce((s, r) => s + Number(r.value), 0);
        const answered = new Set(Array.from(radios).map((r) => r.dataset.q)).size;
        const totalQ = form.querySelectorAll('fieldset').length;
        if (answered < totalQ) {
          alert('Answer every question to learn the truth.');
          return;
        }
        const sorted = results.slice().sort((a, b) => a.threshold - b.threshold);
        let pick = sorted[0];
        for (const r of sorted) if (total >= r.threshold) pick = r;
        document.getElementById('resultTier').textContent = `Score: ${total}`;
        document.getElementById('resultTitle').textContent = pick.title;
        document.getElementById('resultBlurb').textContent = pick.blurb;
        const box = document.getElementById('result');
        box.hidden = false;
        box.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }
  </script>
</BaseLayout>
